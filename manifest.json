{
  "manifest_version": 3,
  "name": "Bookmark Garden",
  "version": "0.1.0",
  "description": "Organise and browse your X bookmarks in a gallery you control.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "icons": {
    "16": "src/assets/icons/icon16.png",
    "32": "src/assets/icons/icon32.png",
    "48": "src/assets/icons/icon48.png",
    "128": "src/assets/icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/i/bookmarks*"],
      "js": ["src/content/content.ts"]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Bookmark Garden",
    "default_icon": {
      "16": "src/assets/icons/icon16.png",
      "32": "src/assets/icons/icon32.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["src/gallery/gallery.html", "src/assets/icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
